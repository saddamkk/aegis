# --- Session ---
# Random string, 32+ characters — encrypts the iron-session cookie.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Database (Supabase REST API) ---
# All three come from: Supabase dashboard -> Project Settings -> API.

# Project URL, e.g. https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_URL= https://bptzoetvabpalltgqhar.supabase.co

# "service_role" secret key. Server-only — used by src/lib/supabase.ts to
# read/write the `users` table, bypassing Row Level Security (all auth
# logic runs server-side in API routes, so RLS on that table doesn't
# apply here). Never expose this key to the browser or a NEXT_PUBLIC_*
# var.
SUPABASE_SERVICE_ROLE_KEY= eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJwdHpvZXR2YWJwYWxsdGdxaGFyIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MzM2NTc2NiwiZXhwIjoyMDk4OTQxNzY2fQ.XEOM5N-iPH9blfS6RPvxAmyCpIiiLkpkXlzyxfbtnxg

# "anon" public key. Not currently read by any app code — the app never
# queries Supabase from the browser, only server-side via the
# service_role key above. Included for when/if client-side Supabase
# access is added later.
SUPABASE_ANON_KEY= eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJwdHpvZXR2YWJwYWxsdGdxaGFyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMzNjU3NjYsImV4cCI6MjA5ODk0MTc2Nn0.HnN4nbrq6E22T-rnOvK4ffWdE84r8SF4bxm_RI4T0iA

# --- One-time setup ---
# The `users` table isn't created automatically — supabase-js talks to
# PostgREST, which can't run arbitrary DDL. Run db/migrations/001_users.sql
# once via the Supabase SQL Editor (dashboard -> SQL Editor -> paste ->
# Run) before signup will work.
