# --- Session ---
# Random string, 32+ characters — encrypts the iron-session cookie.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Database (Supabase Postgres) ---
# Connection string for the `postgres` npm client (raw wire protocol, not
# the Supabase REST API / supabase-js).
#
# Get it from: Supabase dashboard -> Project Settings -> Database ->
# Connection string -> URI. Use the "Transaction" pooler mode (port 6543),
# not "Direct connection" — the direct-connection host is IPv6-only, and
# the pooler avoids exhausting Postgres' connection limit under
# concurrent serverless invocations on Vercel.
#
# Format:
#   postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:6543/postgres
#
# Note the username is "postgres.<project-ref>" (with a dot) in pooler
# mode, not just "postgres".
#
# If your password contains special characters (@, /, :, #, ?, %, etc.),
# percent-encode them before putting the string together, e.g.:
#   node -e "console.log(encodeURIComponent('your-password-here'))"
# An un-encoded '@' or '/' in the password will break URL parsing — the
# client will connect to the wrong host or fail outright.
DATABASE_URL=
