# --- Session ---
# Random string, 32+ characters — encrypts the iron-session cookie.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Same idea, but for the separate admin-panel session (/admin/*). Must be a
# DIFFERENT random string from SESSION_SECRET — the two session systems are
# deliberately isolated, so reusing the same secret would blur that
# boundary even though the cookies have different names.
ADMIN_SESSION_SECRET=

# --- Database (Supabase REST API) ---
# All three come from: Supabase dashboard -> Project Settings -> API.

# Project URL, e.g. https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# "service_role" secret key. Server-only — used by src/lib/supabase.ts to
# read/write the `users` table, bypassing Row Level Security (all auth
# logic runs server-side in API routes, so RLS on that table doesn't
# apply here). Never expose this key to the browser or a NEXT_PUBLIC_*
# var.
SUPABASE_SERVICE_ROLE_KEY=

# "anon" public key. Not currently read by any app code — the app never
# queries Supabase from the browser, only server-side via the
# service_role key above. Included for when/if client-side Supabase
# access is added later.
SUPABASE_ANON_KEY=

# --- Master admin bootstrap ---
# Only read by `npm run seed:admin` (scripts/seed-master-admin.mjs), never
# by the running app. Creates the first master_admin row if none exists
# yet -- idempotent, safe to leave these set. Nothing public can ever
# create a master admin; this script is the only path.
MASTER_ADMIN_EMAIL=
MASTER_ADMIN_PASSWORD=

# --- One-time setup ---
# Neither table is created automatically — supabase-js talks to PostgREST,
# which can't run arbitrary DDL. Run these once via the Supabase SQL
# Editor (dashboard -> SQL Editor -> paste -> Run), in order, before
# signup or the admin panel will work:
#   db/migrations/001_users.sql
#   db/migrations/002_admin.sql
# Then run `npm run seed:admin` to create the first master admin.
