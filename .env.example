# Random string, 32+ characters — used to encrypt the session cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Postgres connection string (Supabase: Project Settings -> Database ->
# Connection string -> URI, use the pooled "Transaction" mode connection
# for serverless deploys, port 6543).
DATABASE_URL=
